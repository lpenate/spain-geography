{
  "name": "spain-geography",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run generate:maps && vue-tsc -b && vite build",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\" \"*.{ts,js,json,html}\"",
    "type-check": "vue-tsc -b --noEmit",
    "lint": "eslint .",
    "generate:maps": "node scripts/generate-maps.mjs"
  },
  "dependencies": {
    "d3-geo": "^3.1.1",
    "pinia": "^3.0.3",
    "topojson-client": "^3.1.0",
    "vue": "^3.5.34",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "es-atlas": "^0.6.0",
    "eslint": "^9.31.0",
    "eslint-plugin-vue": "^10.3.0",
    "globals": "^16.3.0",
    "happy-dom": "^18.0.1",
    "prettier": "^3.6.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.38.0",
    "vite": "^8.0.12",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.2.8"
  }
}
